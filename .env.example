# ─────────────────────────────────────────────────────────────────────────────
# WikiRisk – Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── MinIO (artifact store) ────────────────────────────────────────────────────
MINIO_USER=wikirisk
MINIO_PASSWORD=wikirisk123

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=wikirisk-edit-risk
MLFLOW_MODEL_NAME=wikirisk-risk-classifier

# ── OpenAI (AI explainability layer) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///data/wikirisk.db

# ── UI ────────────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER=local[*]

# ── Streaming ─────────────────────────────────────────────────────────────────
WIKIMEDIA_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json       # json | pretty
