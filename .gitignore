# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Data (large files – track manifests and model, not raw dumps) ─────────────
data/raw/dumps/
data/raw/mediawiki_history/*.bz2
data/processed/
data/stream/
data/predictions/
data/wikirisk.db
*.db
*.db-shm
*.db-wal

# mlruns/ and data/model/ are intentionally tracked:
# they contain training proof and the trained model for sharing.

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.Python
pip-wheel-metadata/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Spark ─────────────────────────────────────────────────────────────────────
derby.log
metastore_db/
spark-warehouse/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
# *.ipynb intentionally tracked — notebooks are part of the project
